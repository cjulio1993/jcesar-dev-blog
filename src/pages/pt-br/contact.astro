---
import BaseLayout from '@/layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contato Julio Cesar',
  url: 'https://jcesar.dev.br/pt-br/contact/'
};
---

<BaseLayout
  title="Contato | jcesar.dev.br"
  description="Entre em contato com Julio Cesar para consultoria backend, projetos Laravel e revisao de arquitetura."
  canonical="https://jcesar.dev.br/pt-br/contact/"
  structuredData={structuredData}
>
  <section class="mx-auto max-w-2xl text-center">
    <h1 class="text-4xl font-bold tracking-tight">Vamos construir algo robusto.</h1>
    <p class="mt-4 text-zinc-600 dark:text-zinc-300">Precisa de ajuda com APIs em Laravel, decisoes de arquitetura ou performance backend? Vamos conversar.</p>
    <div class="mt-8 grid gap-4 text-left sm:grid-cols-2">
      <a href="mailto:hello@jcesar.dev.br" class="card block">
        <h2 class="text-lg font-semibold">Email</h2>
        <p class="mt-2 text-zinc-600 dark:text-zinc-300">hello@jcesar.dev.br</p>
      </a>
      <a href="https://github.com/cjulio1993" target="_blank" rel="noreferrer" class="card block">
        <h2 class="text-lg font-semibold">GitHub</h2>
        <p class="mt-2 text-zinc-600 dark:text-zinc-300">github.com/cjulio1993</p>
      </a>
    </div>
  </section>
</BaseLayout>
