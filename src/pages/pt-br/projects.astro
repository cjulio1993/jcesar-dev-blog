---
import BaseLayout from '@/layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Laravel API Blueprint',
    description: 'Starter kit Laravel escalavel com arquitetura hexagonal, filas e observabilidade.',
    stack: ['Laravel', 'PHP', 'MySQL', 'Redis']
  },
  {
    title: 'Event-Driven Checkout',
    description: 'Arquitetura de referencia para checkout resiliente com processamento assincrono.',
    stack: ['PHP', 'RabbitMQ', 'Docker', 'OpenTelemetry']
  },
  {
    title: 'Headless Content Platform',
    description: 'Backend API-first para publicacao multi-canal com metas estritas de performance.',
    stack: ['Laravel', 'PostgreSQL', 'Vue', 'CI/CD']
  }
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Projetos',
  url: 'https://jcesar.dev.br/pt-br/projects/'
};
---

<BaseLayout
  title="Projetos | jcesar.dev.br"
  description="Projetos selecionados de backend e arquitetura de Julio Cesar."
  canonical="https://jcesar.dev.br/pt-br/projects/"
  structuredData={structuredData}
>
  <section class="mb-8">
    <h1 class="text-4xl font-bold tracking-tight">Projetos</h1>
    <p class="mt-3 max-w-2xl text-zinc-600 dark:text-zinc-300">Portifolio curado de engenharia backend e arquitetura de software.</p>
  </section>

  <section class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {projects.map((project) => (
      <article class="card">
        <h2 class="text-xl font-semibold">{project.title}</h2>
        <p class="mt-3 text-zinc-600 dark:text-zinc-300">{project.description}</p>
        <ul class="mt-4 flex flex-wrap gap-2 text-xs">
          {project.stack.map((item) => <li class="rounded-full border border-zinc-300 px-3 py-1 dark:border-zinc-700">{item}</li>)}
        </ul>
      </article>
    ))}
  </section>
</BaseLayout>
