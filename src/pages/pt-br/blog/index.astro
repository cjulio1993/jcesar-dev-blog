---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { calculateReadingTime, postUrl, sortedPosts, uniqueTags } from '@/utils/blog';

const allPosts = sortedPosts(await getCollection('blog'));
const tags = uniqueTags(allPosts);
const pageSize = 6;
const posts = allPosts.slice(0, pageSize);
const totalPages = Math.ceil(allPosts.length / pageSize);
const searchIndex = allPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  date: post.data.pubDate.toLocaleDateString('pt-BR', { dateStyle: 'medium' }),
  readingTime: calculateReadingTime(post.body),
  url: `/pt-br${postUrl(post)}`,
  searchable: `${post.data.title} ${post.data.description} ${post.data.tags.join(' ')}`.toLowerCase()
}));
---

<BaseLayout
  title="Blog | jcesar.dev.br"
  description="Artigos sobre PHP, Laravel, APIs, arquitetura e desenvolvimento web moderno."
  canonical="https://jcesar.dev.br/pt-br/blog/"
>
  <section class="space-y-6">
    <h1 class="display-title text-4xl font-bold tracking-tight">Blog</h1>
    <p class="max-w-2xl text-zinc-600 dark:text-zinc-300">Conteudos tecnicos e guias praticos sobre engenharia backend, arquitetura de software e web moderna.</p>
    <label class="block">
      <span class="mb-2 block text-sm font-medium">Buscar posts</span>
      <input id="search-input" class="w-full rounded-xl border border-zinc-300 bg-white px-4 py-3 outline-none ring-emerald-500 transition focus:ring dark:border-zinc-700 dark:bg-zinc-900" placeholder="Busque por titulo, descricao ou tag..." type="search" />
    </label>
    <p id="search-count" class="text-sm text-zinc-500 dark:text-zinc-400" aria-live="polite"></p>
    <div class="flex flex-wrap gap-2 text-xs">
      {tags.map((tag) => (
        <a class="rounded-full border border-zinc-300 px-3 py-1 transition hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-800" href={`/pt-br/blog/tags/${tag.toLowerCase()}/`}>#{tag}</a>
      ))}
    </div>
  </section>

  <section class="mt-10 grid gap-6 md:grid-cols-2" id="post-grid">
    {posts.map((post) => (
      <div data-post-card>
        <PostCard post={post} readingTime={calculateReadingTime(post.body)} locale="pt-BR" />
      </div>
    ))}
  </section>

  {totalPages > 1 && (
    <nav class="mt-10 flex items-center gap-3" aria-label="Paginacao" data-default-pagination>
      <span class="text-sm text-zinc-500 dark:text-zinc-400">Pagina 1 de {totalPages}</span>
      <a class="rounded-lg border border-zinc-300 px-4 py-2 text-sm hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-800" href="/pt-br/blog/2/">Proxima pagina</a>
    </nav>
  )}

  <script id="search-index" type="application/json" is:inline set:html={JSON.stringify(searchIndex)} />

  <script is:inline>
    const searchInput = document.querySelector('#search-input');
    const searchCount = document.querySelector('#search-count');
    const grid = document.querySelector('#post-grid');
    const pagination = document.querySelector('[data-default-pagination]');
    const rawIndex = document.querySelector('#search-index')?.textContent ?? '[]';
    const allPosts = JSON.parse(rawIndex);

    const normalize = (value) => value
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .trim();

    const renderResultCards = (items) => {
      if (!grid) return;
      if (!items.length) {
        grid.innerHTML = '<p class="col-span-full rounded-xl border border-zinc-200 p-6 text-zinc-600 dark:border-zinc-800 dark:text-zinc-300">Nenhum post encontrado para este termo.</p>';
        return;
      }

      grid.innerHTML = items.map((item) => `
        <article class="card animate-fade-in-up">
          <p class="text-xs uppercase tracking-wide text-brand-600 dark:text-brand-400">${item.date}</p>
          <h3 class="mt-2 text-xl font-semibold">
            <a href="${item.url}" class="hover:text-brand-600 dark:hover:text-brand-400">${item.title}</a>
          </h3>
          <p class="mt-3 text-zinc-600 dark:text-zinc-300">${item.description}</p>
          <div class="mt-4 flex flex-wrap items-center gap-2 text-xs text-zinc-500 dark:text-zinc-400">
            ${item.tags.map((tag) => `<a class="rounded-full border border-zinc-300 px-2 py-1 dark:border-zinc-700" href="/pt-br/blog/tags/${String(tag).toLowerCase()}/">#${tag}</a>`).join('')}
            <span class="ml-auto">${item.readingTime} min de leitura</span>
          </div>
        </article>
      `).join('');
    };

    const updateCount = (total) => {
      if (!searchCount) return;
      searchCount.textContent = `${total} post${total === 1 ? '' : 's'} encontrado${total === 1 ? '' : 's'}`;
    };

    updateCount(allPosts.length);

    searchInput?.addEventListener('input', (event) => {
      const value = event.target instanceof HTMLInputElement ? normalize(event.target.value) : '';
      if (!value) {
        window.location.href = '/pt-br/blog/';
        return;
      }

      const filtered = allPosts.filter((post) => normalize(post.searchable).includes(value));
      pagination?.classList.add('hidden');
      updateCount(filtered.length);
      renderResultCards(filtered);
    });
  </script>
</BaseLayout>
