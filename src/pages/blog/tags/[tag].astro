---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { calculateReadingTime, sortedPosts } from '@/utils/blog';

export async function getStaticPaths() {
  const posts = sortedPosts(await getCollection('blog'));
  const tags = [...new Set(posts.flatMap((post) => post.data.tags.map((tag) => tag.toLowerCase())))];

  return tags.map((tag) => {
    const filtered = posts.filter((post) => post.data.tags.map((item) => item.toLowerCase()).includes(tag));
    return {
      params: { tag },
      props: { tag, posts: filtered }
    };
  });
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`#${tag} articles | jcesar.dev.br`}
  description={`Posts tagged with ${tag}.`}
  canonical={`https://jcesar.dev.br/blog/tags/${tag}/`}
>
  <section class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight">Tag: #{tag}</h1>
    <p class="mt-2 text-zinc-600 dark:text-zinc-300">{posts.length} article(s) found.</p>
  </section>

  <section class="grid gap-6 md:grid-cols-2">
    {posts.map((post) => <PostCard post={post} readingTime={calculateReadingTime(post.body)} />)}
  </section>
</BaseLayout>
