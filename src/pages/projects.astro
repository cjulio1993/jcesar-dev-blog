---
import BaseLayout from '@/layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Laravel API Blueprint',
    description: 'Scalable Laravel starter kit with hexagonal architecture, queues, and observability.',
    stack: ['Laravel', 'PHP', 'MySQL', 'Redis']
  },
  {
    title: 'Event-Driven Checkout',
    description: 'Reference architecture for resilient checkout flow with asynchronous processing.',
    stack: ['PHP', 'RabbitMQ', 'Docker', 'OpenTelemetry']
  },
  {
    title: 'Headless Content Platform',
    description: 'API-first backend for multi-channel publishing with strict performance budgets.',
    stack: ['Laravel', 'PostgreSQL', 'Vue', 'CI/CD']
  }
];
---

<BaseLayout
  title="Projects | jcesar.dev.br"
  description="Selected backend and architecture projects from Julio Cesar."
  canonical="https://jcesar.dev.br/projects/"
>
  <section class="mb-8">
    <h1 class="text-4xl font-bold tracking-tight">Projects</h1>
    <p class="mt-3 max-w-2xl text-zinc-600 dark:text-zinc-300">A curated portfolio of backend engineering and architecture work.</p>
  </section>

  <section class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {projects.map((project) => (
      <article class="card">
        <h2 class="text-xl font-semibold">{project.title}</h2>
        <p class="mt-3 text-zinc-600 dark:text-zinc-300">{project.description}</p>
        <ul class="mt-4 flex flex-wrap gap-2 text-xs">
          {project.stack.map((item) => <li class="rounded-full border border-zinc-300 px-3 py-1 dark:border-zinc-700">{item}</li>)}
        </ul>
      </article>
    ))}
  </section>
</BaseLayout>
