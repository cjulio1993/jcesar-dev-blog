---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | jcesar.dev.br"
  description="Contact Julio Cesar for backend consulting, Laravel projects, and architecture reviews."
  canonical="https://jcesar.dev.br/contact/"
>
  <section class="mx-auto max-w-2xl text-center">
    <h1 class="text-4xl font-bold tracking-tight">Let's build something robust.</h1>
    <p class="mt-4 text-zinc-600 dark:text-zinc-300">Need help with Laravel APIs, architecture decisions, or backend performance? Let's talk.</p>
    <div class="mt-8 grid gap-4 text-left sm:grid-cols-2">
      <a href="mailto:hello@jcesar.dev.br" class="card block">
        <h2 class="text-lg font-semibold">Email</h2>
        <p class="mt-2 text-zinc-600 dark:text-zinc-300">hello@jcesar.dev.br</p>
      </a>
      <a href="https://github.com/cjulio1993" target="_blank" rel="noreferrer" class="card block">
        <h2 class="text-lg font-semibold">GitHub</h2>
        <p class="mt-2 text-zinc-600 dark:text-zinc-300">github.com/cjulio1993</p>
      </a>
    </div>
  </section>
</BaseLayout>
