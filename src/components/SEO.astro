---
import { buildSeo } from '@/utils/seo';

interface Props {
  title: string;
  description: string;
  canonical: string;
  type?: 'website' | 'article';
  image?: string;
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  structuredData?: Record<string, unknown>;
}

const seo = buildSeo(Astro.props as Props);
---

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonical} />
<meta name="robots" content="index,follow" />
<meta property="og:site_name" content="jcesar.dev.br" />
<meta property="og:type" content={seo.type} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:image" content={seo.image} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
<meta name="twitter:image" content={seo.image} />
{seo.publishedTime && <meta property="article:published_time" content={seo.publishedTime} />}
{seo.modifiedTime && <meta property="article:modified_time" content={seo.modifiedTime} />}
{seo.tags.map((tag) => <meta property="article:tag" content={tag} />)}
{Astro.props.structuredData && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(Astro.props.structuredData)} />
)}
