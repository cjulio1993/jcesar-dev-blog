---
const isPtBr = Astro.url.pathname.startsWith('/pt-br');
const prefix = isPtBr ? '/pt-br' : '';
const description = isPtBr
  ? 'PHP, Laravel, APIs e arquitetura de software.'
  : 'PHP, Laravel, APIs and architecture.';
---

<footer class="border-t border-zinc-200/70 py-10 dark:border-zinc-800">
  <div class="container-shell flex flex-col justify-between gap-4 text-sm text-zinc-600 dark:text-zinc-400 md:flex-row md:items-center">
    <p>© {new Date().getFullYear()} jcesar.dev.br — {description}</p>
    <div class="flex gap-4">
      <a class="hover:text-zinc-950 dark:hover:text-white" href={`${prefix}/rss.xml`}>RSS</a>
      <a class="hover:text-zinc-950 dark:hover:text-white" href="https://github.com/cjulio1993" rel="noreferrer" target="_blank">GitHub</a>
      <a class="hover:text-zinc-950 dark:hover:text-white" href="https://www.linkedin.com" rel="noreferrer" target="_blank">LinkedIn</a>
    </div>
  </div>
</footer>
