---
const path = Astro.url.pathname;
const isPtBr = path.startsWith('/pt-br');
const prefix = isPtBr ? '/pt-br' : '';

const navItems = [
  { href: `${prefix}/`, label: isPtBr ? 'Inicio' : 'Home' },
  { href: `${prefix}/blog/`, label: 'Blog' },
  { href: `${prefix}/projects/`, label: isPtBr ? 'Projetos' : 'Projects' },
  { href: `${prefix}/about/`, label: isPtBr ? 'Sobre' : 'About' },
  { href: `${prefix}/contact/`, label: isPtBr ? 'Contato' : 'Contact' }
];

const toEnglish = path.startsWith('/pt-br') ? (path.replace('/pt-br', '') || '/') : path;
const toPortuguese = path.startsWith('/pt-br') ? path : `/pt-br${path === '/' ? '/' : path}`;

const langLabel = isPtBr ? 'Idioma' : 'Language';
const themeLabel = isPtBr ? 'Tema' : 'Theme';
const menuLabel = isPtBr ? 'Menu' : 'Menu';
---

<header class="sticky top-0 z-40 border-b border-zinc-200/60 bg-white/85 backdrop-blur-md dark:border-zinc-800 dark:bg-zinc-950/80">
  <div class="container-shell flex h-16 items-center justify-between">
    <a href={`${prefix}/`} class="font-display font-semibold tracking-tight">jcesar<span class="text-brand-500">.dev.br</span></a>
    <nav aria-label="Main navigation" class="hidden items-center gap-6 text-sm md:flex">
      {navItems.map((item) => (
        <a class="text-zinc-600 transition hover:text-zinc-950 dark:text-zinc-300 dark:hover:text-white" href={item.href}>{item.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <div class="hidden items-center gap-1 rounded-lg border border-zinc-200 p-1 text-xs dark:border-zinc-700 md:flex" aria-label={langLabel}>
        <a class={`rounded px-2 py-1 transition ${!isPtBr ? 'bg-zinc-900 text-white dark:bg-zinc-100 dark:text-zinc-900' : 'text-zinc-600 dark:text-zinc-300'}`} href={toEnglish}>EN</a>
        <a class={`rounded px-2 py-1 transition ${isPtBr ? 'bg-zinc-900 text-white dark:bg-zinc-100 dark:text-zinc-900' : 'text-zinc-600 dark:text-zinc-300'}`} href={toPortuguese}>PT</a>
      </div>
      <button
        id="theme-toggle"
        class="rounded-lg border border-zinc-200 p-2 text-sm transition hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-800"
        aria-label="Toggle dark mode"
      >
        <span aria-hidden="true">{themeLabel}</span>
      </button>
      <button
        type="button"
        class="rounded-lg border border-zinc-200 px-3 py-1.5 text-xs md:hidden dark:border-zinc-700"
        aria-expanded="false"
        data-mobile-toggle
      >
        {menuLabel}
      </button>
    </div>
  </div>
  <nav class="container-shell hidden pb-4 md:hidden" data-mobile-nav aria-label="Mobile navigation">
    <ul class="space-y-2 text-sm">
      <li class="flex gap-2 px-3 py-2">
        <a class={`rounded border px-2 py-1 text-xs ${!isPtBr ? 'border-zinc-400' : 'border-zinc-200 dark:border-zinc-700'}`} href={toEnglish}>EN</a>
        <a class={`rounded border px-2 py-1 text-xs ${isPtBr ? 'border-zinc-400' : 'border-zinc-200 dark:border-zinc-700'}`} href={toPortuguese}>PT</a>
      </li>
      {navItems.map((item) => (
        <li><a class="block rounded-md px-3 py-2 hover:bg-zinc-100 dark:hover:bg-zinc-800" href={item.href}>{item.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const btn = document.querySelector('#theme-toggle');
  const mobileBtn = document.querySelector('[data-mobile-toggle]');
  const mobileNav = document.querySelector('[data-mobile-nav]');

  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  mobileBtn?.addEventListener('click', () => {
    const isHidden = mobileNav?.classList.toggle('hidden');
    mobileBtn.setAttribute('aria-expanded', String(!isHidden));
  });
</script>
